# Blockchain Gateway Configuration
# Copy to .env and fill in production values

# Connection
BLOCKCHAIN_GATEWAY_RPC_URL=http://localhost:8545
BLOCKCHAIN_GATEWAY_CHAIN_ID=31337

# Contract addresses (set after deployment)
BLOCKCHAIN_GATEWAY_POLICY_REGISTRY_ADDRESS=
BLOCKCHAIN_GATEWAY_AUDIT_EVENT_REGISTRY_ADDRESS=

# Signer (private key for the gateway service account)
BLOCKCHAIN_GATEWAY_SIGNER_PRIVATE_KEY=

# Signer policy (set allow_all=true for dev, false for prod)
BLOCKCHAIN_GATEWAY_SIGNER_POLICY_FILE=signer-policy.yaml

# Outbox
BLOCKCHAIN_GATEWAY_OUTBOX_DB_PATH=outbox.db
BLOCKCHAIN_GATEWAY_OUTBOX_POLL_INTERVAL_SECONDS=5
BLOCKCHAIN_GATEWAY_MAX_RETRIES=5
BLOCKCHAIN_GATEWAY_RETRY_BACKOFF_BASE=2

# Reconciliation
BLOCKCHAIN_GATEWAY_RECONCILIATION_ENABLED=false
BLOCKCHAIN_GATEWAY_RECONCILIATION_CRON=0 */6 * * *
BLOCKCHAIN_GATEWAY_RECONCILIATION_WINDOW_HOURS=24

# API
BLOCKCHAIN_GATEWAY_LOG_LEVEL=INFO
