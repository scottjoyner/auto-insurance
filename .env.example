# Local development only. Do not use these values in production.

QUOTE_SERVICE_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
QUOTE_SERVICE_ALLOW_CREDENTIALS=false
QUOTE_SERVICE_DEFAULT_PRODUCT_YAML=/app/data/sample-products/sample_personal_auto_v1.yml
QUOTE_SERVICE_DATABASE_URL=sqlite:////app/quote_service.db
QUOTE_SERVICE_AUTO_CREATE_SCHEMA=true

RISK_APPETITE_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
RISK_APPETITE_ALLOW_CREDENTIALS=false
RISK_APPETITE_POLICY_PATH=/app/data/risk-appetite-policy.yml
RISK_APPETITE_ENABLE_RUNTIME_POLICY_UPDATE=false

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=auto_insurance
